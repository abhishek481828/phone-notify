{
  "manifest_version": 3,
  "name": "Phone Notify",
  "version": "1.0.0",
  "description": "A beautiful notification dashboard that mirrors your Android notifications in Chrome.",

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "background": {
    "service_worker": "background.js"
  },

  "side_panel": {
    "default_path": "sidepanel.html"
  },

  "permissions": [
    "sidePanel",
    "storage",
    "notifications",
    "alarms"
  ],

  "action": {
    "default_title": "Open Phone Notify"
  }
}
