<?xml version="1.0" encoding="utf-8"?>
<!--
    AndroidManifest.xml — Phone Notify v3
    ────────────────────────────────────────
    v3 additions:
      • READ_PHONE_STATE   — Detect incoming calls via TelephonyManager
      • ANSWER_PHONE_CALLS — Accept a ringing call via TelecomManager (API 26+)
      • CALL_PHONE         — End/reject a call via TelecomManager (API 26+)
      • RECEIVE_BOOT_COMPLETED — Auto-reconnect after device reboot (future)

    Permission notes:
      INTERNET                         — Required by OkHttp for WebSocket
      FOREGROUND_SERVICE               — Required if we later run as a foreground service
      QUERY_ALL_PACKAGES               — Required to resolve app names via PackageManager
                                         (needed because target SDK 34 restricts package visibility)
      READ_PHONE_STATE                 — Allows listening to call state (RINGING/OFFHOOK/IDLE)
                                         Dangerous permission: requested at runtime in MainActivity
      ANSWER_PHONE_CALLS               — Allows acceptRingingCall() (API 26+)
                                         Dangerous permission: requested at runtime in MainActivity
      CALL_PHONE                       — Allows endCall() to reject/end calls
                                         Dangerous permission: requested at runtime in MainActivity
      BIND_NOTIFICATION_LISTENER_SERVICE — Applied to the service, not the app:
                                         This RESTRICTS who can bind (only the OS).
                                         It is NOT a <uses-permission> entry.

    Call handling notes:
      - TelecomManager.acceptRingingCall() is deprecated in API 29 but still functional.
        The proper long-term solution is implementing an InCallService, which is
        significantly more complex. This approach covers API 26–33 reliably.
      - TelecomManager.endCall() is deprecated in API 28. For API 29+ rejection,
        users should swipe the phone notification or a full InCallService is needed.
        We attempt endCall() and log a warning if it fails.
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    package="com.mark.phonenotify">

    <!-- ── Permissions ────────────────────────────────────────────────────── -->

    <!-- OkHttp WebSocket connections over the local network -->
    <uses-permission android:name="android.permission.INTERNET"/>

    <!-- Used if we later wrap the connection in a ForegroundService to survive
         the app being backgrounded or killed by the system. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE"/>

    <!--
        Required on Android 11+ (API 30+) to resolve installed app names via
        PackageManager.getApplicationInfo(). Without this, resolveAppName()
        throws NameNotFoundException for apps not declared in <queries>.
        Marked with a lint suppression because Google Play requires justification
        for this permission in the Play Console submission.
    -->
    <uses-permission
        android:name="android.permission.QUERY_ALL_PACKAGES"
        tools:ignore="QueryAllPackagesPermission"/>

    <!--
        READ_PHONE_STATE — detect call state changes (RINGING / OFF_HOOK / IDLE).
        Required by TelephonyManager.listen() / registerTelephonyCallback().
        This is a "dangerous" permission requested at runtime in MainActivity.
    -->
    <uses-permission android:name="android.permission.READ_PHONE_STATE"/>

    <!--
        ANSWER_PHONE_CALLS — allows TelecomManager.acceptRingingCall() (API 26+).
        Enables the "Answer" button in the extension to pick up incoming calls.
        Dangerous permission — runtime request required.
    -->
    <uses-permission android:name="android.permission.ANSWER_PHONE_CALLS"/>

    <!--
        CALL_PHONE — allows TelecomManager.endCall() to reject/end a call.
        Enables the "Reject" button in the extension.
        Dangerous permission — runtime request required.
    -->
    <uses-permission android:name="android.permission.CALL_PHONE"/>

    <!-- ── Application ────────────────────────────────────────────────────── -->

    <application
        android:allowBackup="true"
        android:usesCleartextTraffic="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.PhoneNotify"
        android:networkSecurityConfig="@xml/network_security_config">

        <!-- ── MainActivity ─────────────────────────────────────────────── -->

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>

        <!--
            ── NotificationListenerService ────────────────────────────────────

            CRITICAL DECLARATION — do not modify without understanding the
            Android notification listener binding contract:

            android:permission="android.permission.BIND_NOTIFICATION_LISTENER_SERVICE"
              → This REQUIRES that only the Android OS (which holds this permission)
                can bind to this service. Prevents malicious apps from binding to it.
                This is a required security control for NotificationListenerService.

            android:exported="true"
              → Must be true because the OS (a different process) needs to bind to it.

            <intent-filter> with BIND_NOTIFICATION_LISTENER_SERVICE action
              → Tells the OS that this service is a notification listener.
                Without this filter, the Notification Access settings screen will
                not show "Phone Notify" in its list, so users cannot grant access.
        -->
        <service
            android:name=".NotificationService"
            android:exported="true"
            android:label="@string/notification_service_label"
            android:permission="android.permission.BIND_NOTIFICATION_LISTENER_SERVICE">

            <intent-filter>
                <action android:name="android.service.notification.NotificationListenerService"/>
            </intent-filter>

        </service>

    </application>

</manifest>
